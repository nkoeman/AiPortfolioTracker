generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MappingStatus {
  UNMAPPED
  MAPPED
  FAILED
}

enum EnrichmentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ExposureSource {
  ISHARES
  VANGUARD
  SPDR
  COMGEST
  VANECK
}

enum ExposureStatus {
  READY
  FAILED
}

enum PortfolioAiSummaryStatus {
  READY
  FAILED
}

enum TransactionType {
  TRADE
  DEPOSIT
  WITHDRAWAL
  CASH_TRANSFER
}

enum AssetType {
  STOCK
  ETF
  BOND
  FUND
  OTHER
}

enum AssetClass {
  EQUITY
  BOND
  COMMODITY
  MIXED
  OTHER
}

enum Region {
  US
  EU
  UK
  GLOBAL
  EM
  APAC
  COUNTRY_SPECIFIC
  UNKNOWN
}


model User {
  id            String                @id @default(cuid())
  email         String                @unique
  clerkUserId   String?               @unique
  emailVerified DateTime?
  name          String?
  image         String?
  // Retained for audit; null for Clerk-created users. Do not remove.
  passwordHash  String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  accounts      Account[]
  sessions      Session[]
  importBatches ImportBatch[]
  transactions  Transaction[]
  dailyValues   DailyPortfolioValue[]
  aiSummaries   PortfolioAiSummary[]
}

// Legacy auth tables retained for backward compatibility with historical data.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ImportBatch {
  id           String        @id @default(cuid())
  userId       String
  source       String
  fileName     String?
  createdAt    DateTime      @default(now())
  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]
}

model Instrument {
  id           String              @id @default(cuid())
  isin         String              @unique
  name         String
  displayName  String?
  figi         String?
  figiComposite String?
  securityType String?
  securityType2 String?
  marketSector String?
  assetClass   String?
  issuer       String?
  countryOfRisk String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  transactions Transaction[]
  listings     InstrumentListing[]
  enrichments  InstrumentEnrichment[]
  profile      InstrumentProfile?
  exposureSnapshots InstrumentExposureSnapshot[]
}

model InstrumentListing {
  id              String        @id @default(cuid())
  isin            String
  exchangeName    String
  exchangeCode    String
  exchangeMic     String?
  degiroBeursCode String?
  eodhdCode       String?       @unique
  currency        String?
  isPrimary       Boolean       @default(false)
  mappingStatus   MappingStatus @default(UNMAPPED)
  mappingError    String?
  lastMappedAt    DateTime?
  lastPriceSyncAt DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  instrument   Instrument    @relation(fields: [isin], references: [isin])
  transactions Transaction[]
  dailyPrices  DailyListingPrice[]

  @@unique([isin, exchangeCode])
  @@index([isin, isPrimary])
  @@index([isin, exchangeMic])
  @@index([isin, degiroBeursCode])
}

model Transaction {
  id            String            @id @default(cuid())
  userId        String
  instrumentId  String
  listingId     String?
  importBatchId String?
  tradeAt       DateTime
  quantity      Decimal           @db.Decimal(20, 8)
  price         Decimal?          @db.Decimal(20, 8)
  transactionCosts Decimal?       @db.Decimal(20, 8)
  valueEur      Decimal?          @db.Decimal(20, 8)
  totalEur      Decimal?          @db.Decimal(20, 8)
  currency      String            @default("EUR")
  exchange      String            @default("UNKNOWN")
  exchangeCode  String            @default("UNKNOWN")
  type          TransactionType   @default(TRADE)
  uniqueKey     String            @unique
  createdAt     DateTime          @default(now())

  user        User               @relation(fields: [userId], references: [id])
  instrument  Instrument         @relation(fields: [instrumentId], references: [id])
  listing     InstrumentListing? @relation(fields: [listingId], references: [id])
  importBatch ImportBatch?       @relation(fields: [importBatchId], references: [id])

  @@index([userId, tradeAt])
  @@index([instrumentId, tradeAt])
  @@index([listingId, tradeAt])
}

model DailyListingPrice {
  id             String   @id @default(cuid())
  listingId      String
  date           DateTime @db.Date
  adjustedClose  Decimal  @db.Decimal(20, 8)
  close          Decimal? @db.Decimal(20, 8)
  currency       String?
  source         String   @default("EODHD")
  fetchedAt      DateTime @default(now())

  listing InstrumentListing @relation(fields: [listingId], references: [id])

  @@unique([listingId, date])
  @@index([date])
}

model DailyPortfolioValue {
  id                   String   @id @default(cuid())
  userId               String
  date                 DateTime @db.Date
  valueEur             Decimal  @db.Decimal(20, 8)
  cumulativeReturnAmountEur Decimal? @db.Decimal(20, 8)
  netExternalFlowEur   Decimal  @db.Decimal(20, 8) @default(0)
  periodReturnPct      Decimal? @db.Decimal(20, 10)
  returnIndex          Decimal? @db.Decimal(20, 10)
  cumulativeReturnPct  Decimal? @db.Decimal(20, 10)
  partialValuation     Boolean  @default(false)
  inputHash            String
  computedAt           DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId, date])
  @@index([date])
}

model SyncLock {
  key       String   @id
  lockedAt  DateTime @default(now())
  expiresAt DateTime
  lockedBy  String?
}

model DegiroVenueMap {
  id              String   @id @default(cuid())
  brokerVenueCode String   @unique
  mic             String
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model EodhdExchange {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String?
  operatingMICs String
  country       String?
  currency      String?
  updatedAt     DateTime @updatedAt

  @@index([code])
}

model FxRate {
  id           String   @id @default(cuid())
  weekEndDate  DateTime @db.Date
  base         String   @default("EUR")
  quote        String
  rate         Decimal  @db.Decimal(20, 10)
  source       String   @default("ECB")
  observedDate DateTime @db.Date
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([weekEndDate, base, quote])
  @@index([quote, weekEndDate])
}

model PortfolioAiSummary {
  id              String                    @id @default(cuid())
  userId          String
  weekEndDate     DateTime                  @db.Date
  windowWeeks     Int                       @default(4)
  inputHash       String
  summaryJson     Json
  summaryMarkdown String?
  model           String
  temperature     Float
  promptVersion   String
  status          PortfolioAiSummaryStatus
  errorMessage    String?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, weekEndDate, windowWeeks])
  @@index([userId, weekEndDate])
}

model InstrumentEnrichment {
  id           String           @id @default(cuid())
  isin         String
  source       String           @default("OPENFIGI")
  status       EnrichmentStatus @default(PENDING)
  errorMessage String?
  fetchedAt    DateTime         @default(now())
  payloadJson  Json
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  instrument Instrument @relation(fields: [isin], references: [isin])

  @@unique([isin, source])
  @@index([source, status])
}

model InstrumentProfile {
  isin            String       @id
  assetType       AssetType
  assetClass      AssetClass
  region          Region
  trackedIndexName String?
  fxHedged        Boolean?
  sector          String?
  industry        String?
  issuer          String?
  countryOfRisk   String?
  confidence      Float        @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  instrument Instrument @relation(fields: [isin], references: [isin])

  @@index([assetType, assetClass])
  @@index([region])
}

model InstrumentExposureSnapshot {
  id           String         @id @default(cuid())
  instrumentId String
  source       ExposureSource
  status       ExposureStatus

  asOfDate     DateTime?      @db.Date
  fetchedAt    DateTime       @default(now())
  expiresAt    DateTime

  payload      Json?
  normalizedPayload Json?
  normalizerVersion String?
  coverageMeta Json?
  sourceMeta   Json?
  errorMessage String?

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  instrument Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)

  @@unique([instrumentId, source])
  @@index([source, status])
}
